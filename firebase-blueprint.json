{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Project": {
      "title": "Project",
      "description": "A collection of conversations and analysis for a specific book/topic",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "ownerId"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "A single Claude project conversation session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "messages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": { "type": "string", "enum": ["user", "assistant"] },
              "content": { "type": "string" }
            }
          }
        }
      },
      "required": ["id", "messages"]
    },
    "Analysis": {
      "title": "Analysis",
      "description": "Gemini-powered pattern analysis results",
      "type": "object",
      "properties": {
        "materialSummary": { "type": "string" },
        "authorLines": {
          "type": "array",
          "items": {
           "type": "object",
           "properties": {
             "line": { "type": "string" },
             "resonance": { "type": "number" }
           }
          }
        },
        "underdevelopedIdeas": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "concept": { "type": "string" },
              "initialIntroduction": { "type": "string" },
              "lackOfFollowThrough": { "type": "string" }
            }
          }
        },
        "conventional": { "type": "object" },
        "unconventional": { "type": "object" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Private user profiles"
    },
    "/users/{userId}/projects/{projectId}": {
      "schema": "Project",
      "description": "User's research projects"
    },
    "/users/{userId}/projects/{projectId}/conversations/{convId}": {
      "schema": "Conversation",
      "description": "Raw transcript material"
    },
    "/users/{userId}/projects/{projectId}/analysis/latest": {
      "schema": "Analysis",
      "description": "The most recent pattern analysis"
    }
  }
}
